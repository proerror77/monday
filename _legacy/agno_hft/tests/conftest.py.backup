@pytest.fixture
def mock_rust_engine():
    """模擬 Rust 引擎固件"""
    engine = MagicMock()
    
    # Mock common methods
    engine.initialize = AsyncMock(return_value={"success": True})
    engine.start_trading = AsyncMock(return_value={"success": True, "session_id": "test_123"})
    engine.stop_trading = AsyncMock(return_value={"success": True})
    engine.get_performance = AsyncMock(return_value={
        "latency_us": 150,
        "throughput": 5000,
        "error_rate": 0.001
    })
    
    return engine


