@pytest.fixture
def temp_config_file(test_config) -> Generator[str, None, None]:
    """臨時配置文件固件"""
    with tempfile.NamedTemporaryFile(mode='w', suffix='.json', delete=False) as f:
        config_dict = {
            "mode": test_config.mode.value,
            "symbols": test_config.symbols,
            "risk_limits": test_config.risk_limits,
            "model_config": test_config.model_config,
            "rust_hft_config": test_config.rust_hft_config,
            "monitoring_config": test_config.monitoring_config
        }
        json.dump(config_dict, f)
        f.flush()
        
        yield f.name
        
        # 清理
        try:
            os.unlink(f.name)
        except FileNotFoundError:
            pass


