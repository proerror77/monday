@pytest.fixture
def mock_hft_system(test_config):
    """模擬 HFT 系統固件"""
    system = HFTSystemIntegration(test_config)
    
    # Mock Rust engine methods
    system._initialize_rust_engine = AsyncMock(return_value={
        "success": True,
        "engine_status": "connected",
        "latency_us": 100
    })
    
    system._emergency_stop_rust_trading = AsyncMock(return_value={
        "success": True
    })
    
    system._get_strategy_performance = AsyncMock(return_value={
        "sharpe_ratio": 1.5,
        "max_drawdown": -0.05,
        "win_rate": 0.6,
        "total_return": 0.15
    })
    
    return system


