# HFT系統統一環境配置文件
# ================================
# 用於docker-compose.unified.yml的環境變量配置

# =================== 基礎設施配置 ===================

# Redis配置
REDIS_PORT=6379
REDIS_MAX_MEMORY=2gb
REDIS_MEMORY_POLICY=allkeys-lru
REDIS_VOLUME=hft_redis_data

# ClickHouse配置  
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=hft_user
CLICKHOUSE_PASSWORD=hft_secure_2025
CLICKHOUSE_DB=hft_market_data
CLICKHOUSE_VOLUME=hft_clickhouse_data

# PostgreSQL配置
POSTGRES_PORT=5432
POSTGRES_DB=hft_system
POSTGRES_USER=hft_user
POSTGRES_PASSWORD=hft_secure_2025
POSTGRES_VOLUME=hft_postgres_data

# Prometheus配置
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=90d
PROMETHEUS_VOLUME=hft_prometheus_data

# Grafana配置
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=hft_grafana_2025
GRAFANA_VOLUME=hft_grafana_data

# =================== 應用層配置 ===================

# Rust HFT核心
GRPC_PORT=50051
RUST_METRICS_PORT=8080
RUST_HTTP_PORT=8081
RUST_LOG=info
HFT_MAX_SYMBOLS=10

# Ops Workspace (L2)
OPS_STREAMLIT_PORT=8501
OPS_API_PORT=8000

# ML Workspace (L3)  
ML_STREAMLIT_PORT=8502
ML_API_PORT=8001

# Master Workspace
MASTER_STREAMLIT_PORT=8504
MASTER_API_PORT=8004

# =================== 共享存儲配置 ===================
ML_MODELS_VOLUME=hft_ml_models

# =================== 本地Ollama配置 ===================
# 注意：確保本地Ollama在localhost:11434運行
OLLAMA_HOST=host.docker.internal
OLLAMA_PORT=11434
OLLAMA_TIMEOUT=30