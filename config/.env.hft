# HFT System Environment Variables
# 根據 Agno 官方標準設置的環境變數配置

# =============================================================================
# API Keys (請設置您的實際 API 密鑰)
# =============================================================================
OPENAI_API_KEY=${OPENAI_API_KEY:-sk-placeholder}
EXA_API_KEY=${EXA_API_KEY:-exa-placeholder}
AGNO_API_KEY=${AGNO_API_KEY:-agno-placeholder}

# =============================================================================
# Docker Compose Configuration
# =============================================================================
COMPOSE_PROJECT_NAME=hft-system
COMPOSE_FILE=docker-compose.hft.yml

# =============================================================================
# Development Settings
# =============================================================================
RUNTIME_ENV=dev
DEBUG_MODE=true

# =============================================================================
# Database Configuration
# =============================================================================
# Master Workspace DB
MASTER_DB_HOST=hft-master-db
MASTER_DB_PORT=5432
MASTER_DB_USER=ai
MASTER_DB_PASS=ai
MASTER_DB_DATABASE=ai

# Ops Workspace DB  
OPS_DB_HOST=hft-ops-db
OPS_DB_PORT=5432
OPS_DB_USER=ai
OPS_DB_PASS=ai
OPS_DB_DATABASE=ai

# ML Workspace DB
ML_DB_HOST=hft-ml-db
ML_DB_PORT=5432
ML_DB_USER=ai
ML_DB_PASS=ai
ML_DB_DATABASE=ai

# =============================================================================
# Infrastructure Configuration
# =============================================================================
# Redis
REDIS_HOST=hft-redis
REDIS_PORT=6379
REDIS_DB=0

# ClickHouse
CLICKHOUSE_HOST=hft-clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =============================================================================
# Application Ports
# =============================================================================
# Master Workspace
HFT_MASTER_UI_PORT=8504
HFT_MASTER_API_PORT=8002
HFT_MASTER_DB_PORT=5432

# Ops Workspace
HFT_OPS_UI_PORT=8503
HFT_OPS_API_PORT=8003
HFT_OPS_DB_PORT=5434

# ML Workspace
HFT_ML_UI_PORT=8502
HFT_ML_API_PORT=8001
HFT_ML_DB_PORT=5433

# Infrastructure
HFT_REDIS_PORT=6379
HFT_CLICKHOUSE_HTTP_PORT=8123
HFT_CLICKHOUSE_NATIVE_PORT=9000

# =============================================================================
# Monitoring and Logging
# =============================================================================
AGNO_MONITOR=True
LOG_LEVEL=INFO

# =============================================================================
# Security Settings
# =============================================================================
# Set to 'production' in production environment
ENVIRONMENT=development