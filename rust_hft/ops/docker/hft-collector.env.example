# Exchanges and symbols
EXCHANGES=binance,bitget
SYMBOLS=BTCUSDT,ETHUSDT

# ClickHouse
CH_URL=https://kcveg5xfsi.ap-northeast-1.aws.clickhouse.cloud:8443
CH_DATABASE=hft_db
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# Batching
BATCH_SIZE=1000
FLUSH_MS=2000

# Depth
DEPTH_MODE=limited
DEPTH_LEVELS=15

# Optional dry run flag literal; set to "--dry-run" or leave empty
DRY_RUN=

# Optional spool (local buffer) limits
#COLLECTOR_SPOOL_DIR=/spool
#COLLECTOR_SPOOL_MAX_BYTES=67108864
#COLLECTOR_SPOOL_DRAIN_LIMIT=5
#COLLECTOR_SPOOL_TTL_SECS=21600

