[package]
name = "hft-collector"
version = "0.1.0"
edition = "2021"
description = "原始行情收集器：直接連接交易所 WS，原樣入庫 ClickHouse"

[dependencies]
# 精簡 tokio 特性，避免 full 帶來的過度編譯
tokio = { version = "1", default-features = false, features = ["rt-multi-thread", "macros", "time", "sync", "net"] }

# 全面改用 rustls，避免 OpenSSL 依賴，縮短編譯時間
tokio-tungstenite = { version = "0.20", default-features = false, features = ["rustls-tls-webpki-roots", "connect"] }
reqwest = { version = "0.11", default-features = false, features = ["json", "rustls-tls"] }
clickhouse = { version = "0.12", default-features = false, features = ["rustls-tls"] }

futures = "0.3"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
clap = { version = "4", features = ["derive"] }
tracing = "0.1"
tracing-subscriber = { version = "0.3", features = ["env-filter"] }
chrono = { version = "0.4", features = ["serde"] }
rust_decimal = { version = "1", features = ["serde"] }
anyhow = "1"
async-trait = "0.1"
urlencoding = "2"
ordered-float = "4"
prometheus = "0.13"
hyper = { version = "0.14", features = ["server", "http1"] }
once_cell = "1.19"

# Removed workspace dependencies for standalone Docker compilation

[features]
default = ["collector-binance", "collector-binance-futures", "collector-bitget", "collector-bybit", "collector-asterdex", "collector-hyperliquid"]
collector-binance = []
collector-binance-futures = []
collector-bitget = []
collector-bybit = []
collector-hyperliquid = []
collector-asterdex = []
# Removed use-adapters feature for standalone Docker compilation
