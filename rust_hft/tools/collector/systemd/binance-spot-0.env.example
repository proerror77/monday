# 基础参数
EXCHANGE=binance
CH_URL=https://kcveg5xfsi.ap-northeast-1.aws.clickhouse.cloud:8443
CH_DATABASE=hft_db
BATCH_SIZE=1000
FLUSH_MS=2000
DEPTH_MODE=both
DEPTH_LEVELS=20
LOB_MODE=row
SHARD_COUNT=2
SHARD_INDEX=0

# 20+ 交易对白名单（留在单行，collector 自动按逗号切分）
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BCHUSDT,BNBUSDT,AVAXUSDT,XRPUSDT,ADAUSDT,DOTUSDT,TRXUSDT,LTCUSDT,LDOUSDT,OPUSDT,ARBUSDT,APTUSDT,SUIUSDT,SEIUSDT,MATICUSDT,ATOMUSDT,LINKUSDT,FTMUSDT

# 可选功能
STORE_RAW=false
DRY_RUN=false
