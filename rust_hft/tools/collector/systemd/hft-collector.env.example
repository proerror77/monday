# 基本配置
EXCHANGES=binance,bitget
SYMBOLS=BTCUSDT,ETHUSDT

# ClickHouse 連線
CH_URL=https://kcveg5xfsi.ap-northeast-1.aws.clickhouse.cloud:8443
CH_DATABASE=hft_db
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=CHANGE_ME

# 批次與 Flush 參數
BATCH_SIZE=1000
FLUSH_MS=2000

# 深度（按需）
DEPTH_MODE=limited
DEPTH_LEVELS=15

# 可選：Dry-run（填入 --dry-run 或留空）
DRY_RUN=

# 可選：本地緩存（避免過量佔用本地空間）
#COLLECTOR_SPOOL_DIR=/var/lib/hft-collector/spool
#COLLECTOR_SPOOL_MAX_BYTES=67108864
#COLLECTOR_SPOOL_DRAIN_LIMIT=5
#COLLECTOR_SPOOL_TTL_SECS=21600

