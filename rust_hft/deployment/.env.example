# HFT 系統環境變數範例
# 複製此文件為 .env 並填入實際值

# ============================================
# 基礎設施
# ============================================

# Redis
REDIS_URL=redis://localhost:6379

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ============================================
# 交易所 API 憑證
# ============================================

# Bitget
BITGET_API_KEY=your_bitget_api_key
BITGET_API_SECRET=your_bitget_api_secret
BITGET_PASSPHRASE=your_bitget_passphrase

# Binance
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Bybit
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret

# Hyperliquid
HYPERLIQUID_PRIVATE_KEY=your_hyperliquid_private_key

# ============================================
# 風控參數
# ============================================

# 最大回撤百分比 (觸發告警)
MAX_DRAWDOWN_PCT=5

# 最大持倉金額 (USD)
MAX_POSITION_USD=100000

# Kill Switch 回撤閾值
KILL_SWITCH_DRAWDOWN_PCT=10

# 延遲告警閾值 (毫秒)
LATENCY_THRESHOLD_MS=25

# ============================================
# 告警配置
# ============================================

# Slack/Discord Webhook URL
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# PagerDuty Integration Key
PAGERDUTY_KEY=

# ============================================
# 雲端部署
# ============================================

# AWS ECR Registry
ECR_REGISTRY=123456789.dkr.ecr.ap-southeast-1.amazonaws.com

# 鏡像標籤
IMAGE_TAG=latest

# AWS Account ID (用於 IRSA)
AWS_ACCOUNT_ID=123456789

# ============================================
# 交易參數
# ============================================

# 交易模式: production, paper, replay
HFT_ENV=development

# 日誌級別: trace, debug, info, warn, error
RUST_LOG=info

# 交易對 (逗號分隔)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
