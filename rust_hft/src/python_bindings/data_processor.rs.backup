/*!
 * 數據處理器 Python 綁定
 */

use pyo3::prelude::*;
use numpy::PyArray2;
use std::collections::HashMap;
use std::sync::Arc;
use crate::integrations::unified_bitget_connector::{UnifiedBitgetConnector, UnifiedBitgetConfig};
use tokio::sync::RwLock;
use tokio::runtime::Runtime;

/// 數據處理模式
#[derive(Debug, Clone)]
pub enum DataMode {
    Mock,      // 模擬數據（測試用）
    RealTime,  // 實時數據
    Historical // 歷史數據
}

/// 數據處理器
#[pyclass]
pub struct DataProcessor {
    buffer_size: usize,
    mode: DataMode,
    initialized: bool,
    // 使用現有的Rust組件！
    bitget_connector: Option<Arc<RwLock<UnifiedBitgetConnector>>>,
    runtime: Option<Arc<Runtime>>,
}

#[pymethods]
impl DataProcessor {
    #[new]
    #[pyo3(signature = (buffer_size=1000, mode="mock"))]
    pub fn new(buffer_size: usize, mode: &str) -> PyResult<Self> {
        let data_mode = match mode {
            "mock" => DataMode::Mock,
            "realtime" => DataMode::RealTime,
            "historical" => DataMode::Historical,
            _ => return Err(pyo3::exceptions::PyValueError::new_err("Invalid mode. Use 'mock', 'realtime', or 'historical'"))
        };
        
        Ok(Self {
            buffer_size,
            mode: data_mode,
            initialized: false,
            bitget_connector: None,
            runtime: None,
        })
    }
    
    /// 初始化真實數據連接 - 驅動現有Rust組件
    pub fn initialize_real_data(&mut self, symbol: String) -> PyResult<bool> {
        match self.mode {
            DataMode::Mock => {
                // 測試模式，不需要真實連接
                self.initialized = true;
                Ok(true)
            },
            DataMode::RealTime => {
                // 使用現有的UnifiedBitgetConnector！
                let config = UnifiedBitgetConfig::default();
                let connector = UnifiedBitgetConnector::new(config);
                
                // 創建Tokio運行時
                let runtime = Runtime::new()
                    .map_err(|e| pyo3::exceptions::PyRuntimeError::new_err(format!("創建運行時失敗: {}", e)))?;
                
                self.bitget_connector = Some(Arc::new(RwLock::new(connector)));
                self.runtime = Some(Arc::new(runtime));
                self.initialized = true;
                
                // TODO: 訂閱指定symbol的數據
                // let _rx = rt.block_on(async { connector.start().await });
                
                Ok(true)
            },
            DataMode::Historical => {
                // TODO: 使用現有的ClickHouse客戶端
                self.initialized = true;
                Ok(true)
            }
        }
    }
    
    /// 處理LOB數據
    pub fn process_lob_data<'py>(
        &self,
        py: Python<'py>,
        data: Vec<Vec<f64>>,
    ) -> PyResult<Bound<'py, PyArray2<f64>>> {
        // 將數據轉換為numpy數組
        if data.is_empty() {
            return Ok(PyArray2::zeros_bound(py, (0, 0), false));
        }
        
        // 創建numpy數組
        let array = PyArray2::from_vec2_bound(py, &data)
            .map_err(|e| pyo3::exceptions::PyRuntimeError::new_err(format!("Failed to create array: {}", e)))?;
        
        Ok(array)
    }
    
    /// 提取特徵
    pub fn extract_features(&self, symbol: String) -> PyResult<HashMap<String, f64>> {
        let mut features = HashMap::new();
        
        match &self.mode {
            DataMode::Mock => {
                // 模擬數據模式 - 用於測試
                features.insert("spread".to_string(), 0.001);
                features.insert("mid_price".to_string(), 45000.0);
                features.insert("volume".to_string(), 1000.0);
                features.insert("data_source".to_string(), 0.0); // 0 = mock
            },
            DataMode::RealTime => {
                // 實時數據模式
                if self.initialized {
                    // 嘗試提取真實特徵
                    match self.extract_real_features(&symbol) {
                        Ok(real_features) => {
                            features.extend(real_features);
                            features.insert("data_source".to_string(), 1.0); // 1 = realtime
                        },
                        Err(_) => {
                            // 如果無法獲取真實數據，回退到模擬數據但標記為降級
                            features.insert("spread".to_string(), 0.001);
                            features.insert("mid_price".to_string(), 45000.0);
                            features.insert("volume".to_string(), 1000.0);
                            features.insert("data_source".to_string(), -1.0); // -1 = degraded
                        }
                    }
                } else {
                    return Err(pyo3::exceptions::PyRuntimeError::new_err("Real-time mode not initialized. Call initialize_real_data() first."));
                }
            },
            DataMode::Historical => {
                // 歷史數據模式
                // TODO: 從ClickHouse獲取歷史數據
                features.insert("spread".to_string(), 0.0015);
                features.insert("mid_price".to_string(), 42000.0);
                features.insert("volume".to_string(), 1500.0);
                features.insert("data_source".to_string(), 2.0); // 2 = historical
            }
        }
        
        // 添加時間戳
        let timestamp = std::time::SystemTime::now()
            .duration_since(std::time::UNIX_EPOCH)
            .unwrap()
            .as_secs_f64();
        features.insert("timestamp".to_string(), timestamp);
        
        Ok(features)
    }
    
    /// 從真實數據源提取特徵 - 驅動現有Rust組件
    fn extract_real_features(&self, symbol: &str) -> PyResult<HashMap<String, f64>> {
        let mut features = HashMap::new();
        
        if let (Some(connector), Some(runtime)) = (&self.bitget_connector, &self.runtime) {
            // 使用現有的Rust組件獲取真實數據
            match runtime.block_on(async {
                use crate::integrations::unified_bitget_connector::BitgetChannel;
                
                // 訂閱實時ticker數據
                let _ = connector.write().await.subscribe(symbol, BitgetChannel::Ticker).await;
                
                // 啟動連接並獲取數據流
                match connector.write().await.start().await {
                    Ok(mut rx) => {
                        // 等待第一個ticker消息 (最多3秒)
                        match tokio::time::timeout(
                            tokio::time::Duration::from_secs(3),
                            rx.recv()
                        ).await {
                            Ok(Some(msg)) => {
                                // 解析實時ticker數據
                                println!("收到 WebSocket 消息: channel={:?}, symbol={}, data={}", 
                                        msg.channel, msg.symbol, msg.data);
                                
                                if let Some(data_arr) = msg.data.as_array() {
                                    if let Some(ticker_data) = data_arr.first() {
                                        let mut real_data = HashMap::new();
                                        
                                        println!("解析 ticker 數據: {:?}", ticker_data);
                                        
                                        // 提取關鍵市場數據
                                        if let Some(last_price) = ticker_data.get("lastPr").and_then(|v| v.as_str()) {
                                            if let Ok(price) = last_price.parse::<f64>() {
                                                real_data.insert("mid_price".to_string(), price);
                                                println!("解析到真實價格: ${}", price);
                                            }
                                        } else {
                                            // 如果 lastPr 不存在，嘗試其他字段
                                            if let Some(price_val) = ticker_data.get("price") {
                                                if let Some(price_str) = price_val.as_str() {
                                                    if let Ok(price) = price_str.parse::<f64>() {
                                                        real_data.insert("mid_price".to_string(), price);
                                                        println!("從 price 字段解析到價格: ${}", price);
                                                    }
                                                }
                                            }
                                        }
                                        
                                        if let Some(bid_price) = ticker_data.get("bidPr").and_then(|v| v.as_str()) {
                                            if let Ok(bid) = bid_price.parse::<f64>() {
                                                real_data.insert("bid_price".to_string(), bid);
                                            }
                                        }
                                        
                                        if let Some(ask_price) = ticker_data.get("askPr").and_then(|v| v.as_str()) {
                                            if let Ok(ask) = ask_price.parse::<f64>() {
                                                real_data.insert("ask_price".to_string(), ask);
                                                
                                                // 計算真實價差
                                                if let Some(bid) = real_data.get("bid_price") {
                                                    real_data.insert("spread".to_string(), ask - bid);
                                                }
                                            }
                                        }
                                        
                                        if let Some(volume) = ticker_data.get("baseVolume").and_then(|v| v.as_str()) {
                                            if let Ok(vol) = volume.parse::<f64>() {
                                                real_data.insert("volume".to_string(), vol);
                                            }
                                        }
                                        
                                        if let Some(change) = ticker_data.get("change").and_then(|v| v.as_str()) {
                                            if let Ok(chg) = change.parse::<f64>() {
                                                real_data.insert("change_24h".to_string(), chg);
                                            }
                                        }
                                        
                                        // 如果沒有解析到價格，使用降級模式返回錯誤
                                        if !real_data.contains_key("mid_price") {
                                            return Err("無法解析到有效的價格數據".to_string());
                                        }
                                        
                                        real_data.insert("data_source".to_string(), 1.0); // 1 = real-time
                                        real_data.insert("status".to_string(), 1.0); // 成功獲取真實數據
                                        
                                        Ok(real_data)
                                    } else {
                                        Err("Empty ticker data array".to_string())
                                    }
                                } else {
                                    Err("Invalid ticker data format".to_string())
                                }
                            }
                            Ok(None) => Err("Connection closed".to_string()),
                            Err(_) => Err("Timeout waiting for ticker data".to_string()),
                        }
                    }
                    Err(e) => Err(format!("Failed to start connector: {}", e))
                }
            }) {
                Ok(real_data) => {
                    features.extend(real_data);
                }
                Err(e) => {
                    // 如果真實數據獲取失敗，返回錯誤而不是假數據
                    return Err(pyo3::exceptions::PyRuntimeError::new_err(format!("獲取真實數據失敗: {}", e)));
                }
            }
        } else {
            return Err(pyo3::exceptions::PyRuntimeError::new_err("Bitget連接器未初始化"));
        }
        
        Ok(features)
    }
}