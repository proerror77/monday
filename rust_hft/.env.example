# Hyperliquid 环境变量示例
# 复制此文件为 .env 并填入您的实际值

# Hyperliquid 账户配置
HYPERLIQUID_PRIVATE_KEY=your_64_character_hex_private_key_here
HYPERLIQUID_VAULT_ADDRESS=  # 可选，如果使用 vault 账户

# 网络配置
HYPERLIQUID_REST_URL=https://api.hyperliquid.xyz
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# 风控参数
MAX_POSITION_USD=10000
MAX_DAILY_LOSS_USD=1000
MAX_ORDER_SIZE_BTC=0.1

# 日志配置
LOG_LEVEL=info
LOG_FILE=logs/hyperliquid.log

# 交易配置
TRADING_MODE=paper  # paper 或 live
ENABLE_STRATEGIES=trend,arbitrage